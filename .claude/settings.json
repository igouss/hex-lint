{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "(cargo fmt --all -- --check 1>&2 && cargo clippy --all-targets --all-features -- -D warnings 1>&2) || exit 2",
            "if": "Bash(git commit*)",
            "timeout": 120,
            "statusMessage": "Running cargo fmt --check + clippy"
          }
        ]
      }
    ]
  }
}
